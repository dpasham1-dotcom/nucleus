  "instructions_to_main_agent": [
    "CRITICAL: Implement a 'ThemeWrapper' component that listens to the current route and updates CSS variables for --bg-color, --accent-color, etc.",
    "Do NOT use generic shadcn cards. Heavily style them to match the 'Old Money Tech' aesthetic (border-black/5, warm white bg).",
    "Habit Tracker Grid must be 10x9. It is the core visual.",
    "BQ Practice module must be DARK MODE (#1C1917 bg). All other modules are Light/Warm.",
    "Use Playfair Display for ALL headings. Import it via Google Fonts in index.css.",
    "Ensure the gold accent (#C9A96E) is present in every module as a unifying thread (e.g., active tab, primary button, progress bar).",
    "For the Landing Page, use the 'login_hero' image with a clean, centered login box.",
    "Install 'framer-motion' for page transitions.",
    "Use 'sonner' for toasts.",
    "Do NOT ask the user for clarification. Use these guidelines as the source of truth."
  ],
  "universal_guidelines": [
    "Avoid generic 'AI slop' aesthetics (standard centered layouts, default blue/purple gradients).",
    "Dark colors look good when used independently without gradients.",
    "Create depth through layered design elements with z-index hierarchy.",
    "Use glass-morphism effects with backdrop filters (12-24px blur).",
    "Every interaction needs micro-animations.",
    "Use 2-3x more spacing than feels comfortable.",
    "Subtle grain textures separates good from extraordinary.",
    "All interactive elements MUST include data-testid."
  ]
}